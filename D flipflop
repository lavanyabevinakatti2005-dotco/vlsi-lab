Program: D-Flip Flop
module d_flip_flop(clk, rst, D, q);
input clk;
input rst;
input D;
output reg q;
always @(posedge clk or posedge rst)
begin
if(rst)
  q = 1'b0;
else
  q = D;
end
endmodule

