module modN_counter #(
    parameter N = 10,         // Modulus of the counter
    parameter WIDTH = 4       // Number of bits required to store N-1
)(
    input wire clk,           // Clock signal
    input wire rst,           // Asynchronous active-high reset
    output reg [WIDTH-1:0] count // Counter output
);

    always @(posedge clk or posedge rst) begin
        if (rst) begin
            count <= 0;
        end
        else if (count == N - 1) begin
            count <= 0;       // Reset to 0 when max count is reached
        end
        else begin
            count <= count + 1; // Increment counter
        end
    end

endmodule


`timescale 1ns / 1ps

module tb_modN_counter;

    // Inputs
    reg clk;
    reg rst;

    // Outputs
    wire [3:0] count;

    // Instantiate the Unit Under Test (UUT)
    // Configuring for a MOD-10 Counter
    modN_counter #( .N(10), .WIDTH(4) ) dut (
        .clk(clk),
        .rst(rst),
        .count(count)
    );

    // Clock generation (Period = 10ns)
    initial begin
        clk = 0;
        always #5 clk = ~clk;
    end

    // Stimulus block
    initial begin
        // Initialize and apply reset
        rst = 1;
        #10;
        
        // Release reset to start counting
        rst = 0;
        
        // Run simulation long enough to observe rolling over
        #150;
        
        $finish;
    end

endmodule
